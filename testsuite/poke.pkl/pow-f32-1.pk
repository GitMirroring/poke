/* { dg-do run } */

var a = stof ("3.14"),
    b = stof ("2.71"),
    c = stof ("22.216691971") & ~7 /* Ignore 3 least-significant bits */;

assert (a == 0x4048f5c3);
assert (b == 0x402d70a4);
assert (c == (0x41b1bbc9 & ~7));

/* { dg-command { .set obase 10 } } */
/* { dg-command { ((a .** b) & ~7) == c } } */
/* { dg-output 1 } */

/* For constant folding: */
/* { dg-command { .set obase 16 } } */
/* { dg-command { (0x4048f5c3 .** 0x402d70a4) & ~7 } } */
/* { dg-output "\n0x41b1bbc8U" } */
